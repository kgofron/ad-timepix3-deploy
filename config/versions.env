# Pinned EPICS / areaDetector release tags (edit for your site).
# Tested reference stack (ORNL dev machine, 2026-06):

EPICS_BASE_TAG=R7.0.10

ASYN_TAG=R4-45
AUTOSAVE_TAG=R5-10-2
BUSY_TAG=R1-7-3
CALC_TAG=R3-7-4
SNCSEQ_TAG=R2-2-9
# GitHub repo is epics-modules/sequencer; install dir is ${SUPPORT}/seq (SNCSEQ)
SNCSEQ_GIT_REPO=sequencer
# R2-11-5+ required for EPICS 7 (READONLY in saveData_writeXDR.c; R2-11-4 fails)
SSCAN_TAG=R2-11-5
IOCSTATS_TAG=4.0.0

# ADCore master needs ADSupport master (lz4hdf5Src); R1-10 is too old for WITH_BITSHUFFLE=YES
# master ≈ forthcoming ADCore R3-15 (not yet tagged — latest tag is R3-14).
# Phoebus lab tree in this repo: bob/ADet/R3-15/ (name tracks that stack).
ADCORE_TAG=master
ADSUPPORT_TAG=master

# MediPix3 development driver (kgofron fork); merge target: areaDetector/ADTimePix3
ADTIMEPix3_REPO=https://github.com/kgofron/ADTimePix3.git
ADTIMEPix3_BRANCH=medipix3-integration
ADTIMEPix3_DIRNAME=ADTimePix3_mpx3

# Phoebus — source selected in site.env (PHOEBUS_SOURCE=github|sns)
# GitHub: https://github.com/ControlSystemStudio/phoebus/releases
PHOEBUS_VERSION=4.7.4
PHOEBUS_GITHUB_PRODUCT=phoebus-${PHOEBUS_VERSION}-linux.tar.gz
# SNS/ORNL: https://controlssoftware.sns.ornl.gov/css_phoebus/ (nightly product-sns-linux.zip)
PHOEBUS_SNS_URL=https://controlssoftware.sns.ornl.gov/css_phoebus/nightly/product-sns-linux.zip
