# Pinned EPICS / areaDetector release tags (edit for your site).
# Tested reference stack (ORNL dev machine, 2026-06):

EPICS_BASE_TAG=R7.0.10

ASYN_TAG=R4-45
AUTOSAVE_TAG=R5-10-2
BUSY_TAG=R1-7-3
CALC_TAG=R3-7-4
SNCSEQ_TAG=R2-2-9
# GitHub repo is epics-modules/sequencer; install dir is ${SUPPORT}/seq (SNCSEQ)
SNCSEQ_GIT_REPO=sequencer
SSCAN_TAG=R2-11-4
IOCSTATS_TAG=4.0.0

ADCORE_TAG=master
ADSUPPORT_TAG=R1-10

# MediPix3 development driver (kgofron fork); merge target: areaDetector/ADTimePix3
ADTIMEPix3_REPO=https://github.com/kgofron/ADTimePix3.git
ADTIMEPix3_BRANCH=medipix3-integration
ADTIMEPix3_DIRNAME=ADTimePix3_mpx3

# Phoebus — see https://github.com/ControlSystemStudio/phoebus/releases
PHOEBUS_VERSION=4.7.4
PHOEBUS_PRODUCT=phoebus-product-${PHOEBUS_VERSION}.zip
