# Copy to config/site.env and customize for the target host.
# Sourced by all install scripts.

EPICS_ROOT=/epics
SUPPORT=${EPICS_ROOT}/support
EPICS_BASE=${EPICS_ROOT}/epics-base
GUI_ROOT=${EPICS_ROOT}/GUI

# areaDetector umbrella path (ADCore, ADSupport, drivers)
AREA_DETECTOR=${SUPPORT}/areaDetector

# Parallel checkout name for MediPix3 driver work
ADTIMEPix3_HOME=${AREA_DETECTOR}/ADTimePix3_mpx3

PHOEBUS_HOME=${GUI_ROOT}/phoebus
BOB_ROOT=${GUI_ROOT}/bob

# Phoebus product: sns (ORNL/SNS/HFIR zip + bundled jdk) or github (generic tar.gz, needs Java)
# Off-site / non-SNS: PHOEBUS_SOURCE=github
PHOEBUS_SOURCE=sns

# EPICS build host arch (usually linux-x86_64)
EPICS_HOST_ARCH=linux-x86_64

# PV prefix — must match PREFIX in driver st_*.cmd (MediPix3 st_mpx3.cmd: MPX3-TEST:)
IOC_PREFIX=MPX3-TEST:
SERVER_URL=http://localhost:8081

# IOC startup script in iocs/tpx3IOC/iocBoot/iocTimePix/ (MediPix3: st_mpx3.cmd; TimePix3: st.cmd)
IOC_STARTUP=st_mpx3.cmd

# Default Phoebus screen (filename or path); launch-phoebus.sh searches site bob/ then driver bob/
# Lab launcher: main/detectors.bob — or open driver MediPix3/MediPix3.bob directly
PHOEBUS_DEFAULT_SCREEN=main/detectors.bob

# Git clone depth (0 = full history)
GIT_DEPTH=1

# Number of parallel make jobs (empty = nproc)
MAKE_JOBS=

# Java for Phoebus (Ubuntu 24.04: openjdk-17-jre-headless)
JAVA_HOME=
