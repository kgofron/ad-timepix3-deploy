        <macros>
          <P>$(Sys)$(Dev)</P>
          <R>$(Cam)</R>
        </macros>
        <target>tab</target>
      </action>
      <action type="open_display">
        <description>ADMediPix3</description>
        <file>../../ADTimePix3/R1-0/MediPix3/MediPix3.bob</file>
        <macros>
          <P>$(Sys)$(Dev)</P>
          <R>$(Cam)</R>
