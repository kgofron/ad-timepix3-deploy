<?xml version="1.0" encoding="UTF-8"?>
<!-- ad-timepix3-deploy: Expert opens vendored ADet/R3-15/ADTimePix3/R1-0/ screens
     (relative path from subscreens/, same pattern as SNS ADet/R3-11). -->
<display version="2.0.0">
  <macros>
    <P>$(Sys)$(Dev)</P>
    <R>$(Cam)</R>
    <CORE_VER>R3-15</CORE_VER>
  </macros>
  <width>350</width>
  <height>480</height>
  <background_color>
    <color red="240" green="240" blue="240">
    </color>
  </background_color>
  <actions>
  </actions>
  <grid_step_x>6</grid_step_x>
  <grid_step_y>6</grid_step_y>
  <widget type="label" version="2.0.0">
    <name>Label</name>
    <text>Exposure Time</text>
    <x>12</x>
    <y>5</y>
    <width>157</width>
    <vertical_alignment>1</vertical_alignment>
    <wrap_words>false</wrap_words>
    <actions>
    </actions>
    <border_color>
